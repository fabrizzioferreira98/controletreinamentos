{
    admin off
    email admin@seudominio.com
}

(common_security) {
    encode zstd gzip
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

(tripulante_pdf_preview_embedding) {
    @tripulante_file_pdf_preview {
        method GET HEAD
        path /api/v1/tripulantes/*/files/*
    }
    header @tripulante_file_pdf_preview {
        >X-Frame-Options "SAMEORIGIN"
        >Content-Security-Policy "default-src 'self'; frame-ancestors 'self'; object-src 'none'; base-uri 'self'"
    }
}

app.seudominio.com {
    import common_security
    import tripulante_pdf_preview_embedding
    root * C:/srv/controle-treinamentos/frontend/prod

    @frontend_entry {
        method GET HEAD
        path / /login /logout /index.html
    }
    handle @frontend_entry {
        header {
            Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
            Pragma "no-cache"
            Expires "0"
        }
        rewrite * /index.html
        file_server
    }

    @frontend_assets_immutable {
        method GET HEAD
        path_regexp frontend_immutable ^/(?:[^/?#]+/)*[^/?#]+\.[0-9]{8}-[0-9]{6}\.[0-9a-f]{12}\.(?:js|css)$
    }
    handle @frontend_assets_immutable {
        header {
            Cache-Control "public, max-age=31536000, immutable"
        }
        file_server
    }

    @frontend_assets_unfingerprinted {
        method GET HEAD
        path_regexp frontend_unfingerprinted ^(?:(?:/(?:app|config|lib|shell|pages-[^/?#]+)\.js)|(?:/app\.css)|(?:/(?:app|compat|features|services|shared|shell|state)/.*\.(?:js|css)))$
    }
    handle @frontend_assets_unfingerprinted {
        header {
            Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
            Pragma "no-cache"
            Expires "0"
        }
        respond "stale frontend asset path: use asset-manifest.json fingerprinted URLs" 410
    }

    @frontend_assets_mutable {
        method GET HEAD
        path /asset-manifest.json /login-citation-jet.jpg
    }
    handle @frontend_assets_mutable {
        header {
            Cache-Control "no-cache, max-age=0, must-revalidate"
        }
        file_server
    }

    handle {
        reverse_proxy 127.0.0.1:8101
    }

    log {
        output file C:/srv/controle-treinamentos/logs/caddy/prod-access.log
        format console
    }
}

teste.seudominio.com {
    import common_security
    import tripulante_pdf_preview_embedding
    root * C:/srv/controle-treinamentos/frontend/hml

    @frontend_entry {
