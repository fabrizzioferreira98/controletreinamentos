APP_ENV=production
SECRET_KEY=troque-por-uma-chave-longa-e-unica
SECRET_KEY_FINGERPRINT=
DATABASE_URL=postgresql://ct_prod_user:troque-a-senha@127.0.0.1:5432/ct_prod
ALLOW_LOCAL_DATABASE_IN_SECURE_ENV=1
ALLOW_INSECURE_HTTP_IN_SECURE_ENV=0
PG_BIN_DIR=C:\Program Files\PostgreSQL\17\bin
TRUST_PROXY_HEADERS=1
FRONTEND_PUBLIC_ORIGIN=https://app.seudominio.com
FRONTEND_LOCAL_ORIGIN=http://192.168.25.33
FRONTEND_ALLOWED_ORIGINS=https://app.seudominio.com
WORKSPACE_RUNTIME_ROOT=D:\srv-data\controle-treinamentos\prod\runtime
WORKSPACE_EVIDENCE_ROOT=D:\srv-data\controle-treinamentos\prod\evidence
WORKSPACE_LOCAL_BACKUPS_ROOT=E:\backups\controle-treinamentos\prod
APP_INSTANCE_PATH=D:\srv-data\controle-treinamentos\prod\runtime\instance
MEDIA_STORAGE_ROOT=D:\srv-data\controle-treinamentos\prod\uploads
PORT=8101
WAITRESS_HOST=127.0.0.1
WAITRESS_THREADS=8
WAITRESS_CONNECTION_LIMIT=200
WAITRESS_CHANNEL_TIMEOUT=120
WAITRESS_CLEANUP_INTERVAL=30
WAITRESS_TRUSTED_PROXY=127.0.0.1
WAITRESS_TRUSTED_PROXY_COUNT=1
WAITRESS_TRUSTED_PROXY_HEADERS=x-forwarded-for x-forwarded-host x-forwarded-proto x-forwarded-port
WAITRESS_CLEAR_UNTRUSTED_PROXY_HEADERS=1
WAITRESS_LOG_UNTRUSTED_PROXY_HEADERS=0
SESSION_COOKIE_NAME=ct_prod_session
REMEMBER_COOKIE_NAME=ct_prod_remember
SESSION_COOKIE_SAMESITE=None
SESSION_COOKIE_PATH=/
REMEMBER_COOKIE_PATH=/
COOKIE_DOMAIN=.seudominio.com
AUTH_FAILURE_ALERT_THRESHOLD=20
AUTH_FAILURE_ALERT_WINDOW_SECONDS=300
AUTH_FAILURE_ALERT_MIN_INTERVAL_SECONDS=60
METRICS_TOKEN=troque-por-um-token-forte
CRON_SECRET=troque-por-um-token-forte
BOOTSTRAP_ADMIN_LOGIN=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=admin@seudominio.com
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_USER=usuario
SMTP_PASSWORD=senha
SMTP_SENDER=notificacoes@seudominio.com
SMTP_USE_TLS=1
BACKUP_DIR=E:\backups\controle-treinamentos\prod
BACKUP_RETENTION_DAYS=30
BACKUP_INCLUDE_PATHS=D:\srv-data\controle-treinamentos\prod\uploads
BACKUP_CONFIG_PATHS=C:\srv\controle-treinamentos\env,C:\srv\controle-treinamentos\caddy,C:\srv\controle-treinamentos\tasks
BACKUP_ALLOW_LOGICAL_FALLBACK=0
BACKUP_EXTERNAL_MIRROR_DIR=\\servidor-backup\controle-treinamentos\prod
BACKUP_EXTERNAL_MIRROR_REQUIRED=0
MONITORING_STORAGE_WARNING_PERCENT=75
MONITORING_STORAGE_CRITICAL_PERCENT=90
