APP_ENV=development
FLASK_DEBUG=0
SECRET_KEY=troque-por-uma-chave-longa-e-secreta
DEV_FALLBACK_SECRET_KEY=dev-insecure-secret-key
DATABASE_URL=postgresql://ct_local_user:troque-a-senha@127.0.0.1:5432/ct_local
ALLOW_LOCAL_DATABASE_IN_SECURE_ENV=0
ALLOW_INSECURE_HTTP_IN_SECURE_ENV=0
PG_BIN_DIR=
SESSION_HOURS=8
TRUST_PROXY_HEADERS=0
SESSION_COOKIE_SAMESITE=Lax
SECRET_KEY_FINGERPRINT=
AUTO_MIGRATE_ON_BOOT=0
BOOTSTRAP_ADMIN_LOGIN=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=admin@interno.local
E2E_DATABASE_URL=
E2E_LOGIN=qa_admin
E2E_PASSWORD=
LOADTEST_PASSWORD=
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=10
LOGIN_ATTEMPT_WINDOW_SECONDS=300
LOGIN_LOCKOUT_MINUTES=15
LOGIN_LOCKOUT_SECONDS=900
REMEMBER_COOKIE_DAYS=7
WTF_CSRF_TIME_LIMIT_SECONDS=3600
SESSION_COOKIE_NAME=controle_treinamentos_session
REMEMBER_COOKIE_NAME=controle_treinamentos_remember
SESSION_COOKIE_PATH=/
REMEMBER_COOKIE_PATH=/
# COOKIE_DOMAIN=.seudominio.com
PORT=5000
WAITRESS_HOST=127.0.0.1
WAITRESS_THREADS=8
WAITRESS_CONNECTION_LIMIT=100
WAITRESS_CHANNEL_TIMEOUT=120
WAITRESS_CLEANUP_INTERVAL=30
WAITRESS_TRUSTED_PROXY=127.0.0.1
WAITRESS_TRUSTED_PROXY_COUNT=1
WAITRESS_TRUSTED_PROXY_HEADERS=x-forwarded-for x-forwarded-host x-forwarded-proto x-forwarded-port
WAITRESS_CLEAR_UNTRUSTED_PROXY_HEADERS=1
WAITRESS_LOG_UNTRUSTED_PROXY_HEADERS=0
# Local canonico por padrao: backend compat/hibrido na mesma origem.
# So preencha FRONTEND_* quando houver frontend estatico real servido em outra origem local.
FRONTEND_PUBLIC_ORIGIN=
FRONTEND_LOCAL_ORIGIN=
FRONTEND_ALLOWED_ORIGINS=
# AISWEB/DECEA MET fica restrito ao backend. Nunca use estas credenciais no frontend.
AISWEB_API_KEY=
AISWEB_API_PASS=
AISWEB_BASE_URL=http://aisweb.decea.gov.br/api/
AISWEB_MET_CACHE_TTL_SECONDS=180
AISWEB_NOTAM_CACHE_TTL_SECONDS=300
AISWEB_TIMEOUT_SECONDS=8
# Para validar uploads/downloads/PDFs com paridade minima, use caminhos explicitos fora do checkout.
WORKSPACE_RUNTIME_ROOT=
WORKSPACE_EVIDENCE_ROOT=
WORKSPACE_LOCAL_BACKUPS_ROOT=
APP_INSTANCE_PATH=
MEDIA_STORAGE_ROOT=
AUTH_FAILURE_ALERT_THRESHOLD=20
AUTH_FAILURE_ALERT_WINDOW_SECONDS=300
AUTH_FAILURE_ALERT_MIN_INTERVAL_SECONDS=60
METRICS_TOKEN=
CRON_SECRET=troque-por-um-token-longo
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_USER=usuario
SMTP_PASSWORD=
SMTP_SENDER=notificacoes@seudominio.com
SMTP_USE_TLS=1
RESEND_API_KEY=
RESEND_FROM=notificacoes@seudominio.com
BACKUP_DIR=
BACKUP_RETENTION_DAYS=15
BACKUP_INCLUDE_PATHS=./backend/src/controle_treinamentos/static
BACKUP_CONFIG_PATHS=
BACKUP_ALLOW_LOGICAL_FALLBACK=1
BACKUP_EXTERNAL_MIRROR_DIR=
BACKUP_EXTERNAL_MIRROR_REQUIRED=0
BACKUP_REMOTE_ENABLED=0
BACKUP_REMOTE_REQUIRED=0
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
BACKUP_S3_ENDPOINT_URL=
BACKUP_S3_PREFIX=treinamentos-backups
BACKUP_S3_SSE=AES256
BACKUP_S3_KMS_KEY_ID=
JOB_STALE_LOCK_SECONDS=3600
JOB_WORKER_MAX_JOBS=25
JOB_AUTO_CLEANUP_ENABLED=1
JOB_SUCCESS_RETENTION_DAYS=30
JOB_FAILED_RETENTION_DAYS=90
JOB_EXECUTION_RETENTION_DAYS=30
OPTIONS_CACHE_TTL_SECONDS=600
MONITORING_JOB_QUEUE_WARNING_SIZE=20
MONITORING_JOB_QUEUE_CRITICAL_SIZE=100
MONITORING_JOB_QUEUE_OLDEST_WARNING_MINUTES=30
MONITORING_JOB_QUEUE_OLDEST_CRITICAL_MINUTES=120
TRAINING_ATTACHMENT_MAX_MB=8
MONITORING_ERROR_ALERT_WINDOW_MINUTES=15
MONITORING_ERROR_WARNING_THRESHOLD=5
MONITORING_ERROR_CRITICAL_THRESHOLD=15
MONITORING_CONTRACT_ERROR_WARNING_THRESHOLD=3
MONITORING_CONTRACT_ERROR_CRITICAL_THRESHOLD=8
MONITORING_STORAGE_WARNING_PERCENT=75
MONITORING_STORAGE_CRITICAL_PERCENT=90
